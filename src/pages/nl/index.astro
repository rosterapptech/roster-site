---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import PolyculeMap from '../../components/PolyculeMap.astro';
import Vio from '../../components/Vio.astro';

const lang = 'nl';

const features = [
  {
    slug: 'connections',
    name: 'Verbindingen',
    desc: 'Alle relaties op één plek — met type, beschermingsstatus en een snelle contactlog.',
    icon: `<svg width="34" height="34" viewBox="0 0 34 34" fill="none" xmlns="http://www.w3.org/2000/svg"><circle cx="12" cy="13" r="5" stroke="#8b5cf6" stroke-width="2"/><path d="M3 28c0-4.418 4.03-8 9-8s9 3.582 9 8" stroke="#8b5cf6" stroke-width="2" stroke-linecap="round"/><circle cx="25" cy="11" r="4" stroke="#c4b5fd" stroke-width="1.75"/><path d="M20 26c0-3.314 2.686-6 6-6" stroke="#c4b5fd" stroke-width="1.75" stroke-linecap="round"/></svg>`,
  },
  {
    slug: 'polycule-map',
    name: 'Polycule Map',
    desc: 'Jouw relatienetwerk als een levende kaart. Jij in het midden, alle verbindingen eromheen, op type ingekleurd.',
    icon: `<svg width="34" height="34" viewBox="0 0 34 34" fill="none" xmlns="http://www.w3.org/2000/svg"><circle cx="17" cy="17" r="4" fill="#8b5cf6"/><circle cx="6" cy="9" r="3" stroke="#8b5cf6" stroke-width="1.75"/><circle cx="28" cy="9" r="3" stroke="#c4b5fd" stroke-width="1.75"/><circle cx="6" cy="25" r="3" stroke="#4fd6c2" stroke-width="1.75"/><circle cx="28" cy="25" r="3" stroke="#f0789f" stroke-width="1.75"/><line x1="17" y1="17" x2="6" y2="9" stroke="#8b5cf6" stroke-width="1.5" stroke-opacity="0.6"/><line x1="17" y1="17" x2="28" y2="9" stroke="#c4b5fd" stroke-width="1.5" stroke-opacity="0.6"/><line x1="17" y1="17" x2="6" y2="25" stroke="#4fd6c2" stroke-width="1.5" stroke-opacity="0.6"/><line x1="17" y1="17" x2="28" y2="25" stroke="#f0789f" stroke-width="1.5" stroke-opacity="0.6"/></svg>`,
  },
  {
    slug: 'wellness',
    name: 'Wellness',
    desc: 'Houd soa-tests en check-ins bij — discreet, lokaal, alleen voor jouw ogen.',
    icon: `<svg width="34" height="34" viewBox="0 0 34 34" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M17 29C17 29 5 22 5 13a7 7 0 0 1 12-4.9A7 7 0 0 1 29 13c0 9-12 16-12 16z" stroke="#8b5cf6" stroke-width="2" stroke-linejoin="round"/><path d="M12 17l3 3 6-6" stroke="#c4b5fd" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
  },
  {
    slug: 'reflection',
    name: 'Reflectie',
    desc: 'Een dagboek voor jaloezie, compersie en alles daartussenin. Om te ordenen, niet te oordelen.',
    icon: `<svg width="34" height="34" viewBox="0 0 34 34" fill="none" xmlns="http://www.w3.org/2000/svg"><rect x="6" y="5" width="16" height="24" rx="3" stroke="#8b5cf6" stroke-width="2"/><path d="M22 8h3a3 3 0 0 1 3 3v13a3 3 0 0 1-3 3h-3" stroke="#c4b5fd" stroke-width="1.75"/><line x1="10" y1="11" x2="18" y2="11" stroke="#8b5cf6" stroke-width="1.75" stroke-linecap="round"/><line x1="10" y1="16" x2="18" y2="16" stroke="#8b5cf6" stroke-width="1.75" stroke-linecap="round"/><line x1="10" y1="21" x2="15" y2="21" stroke="#8b5cf6" stroke-width="1.75" stroke-linecap="round"/></svg>`,
  },
  {
    slug: 'insights',
    name: 'Inzichten',
    desc: 'Zachte patronen in plaats van koude cijfers: waar investeer je energie, waar wordt het stil?',
    icon: `<svg width="34" height="34" viewBox="0 0 34 34" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M5 24l7-7 5 4 8-10 4 4" stroke="#8b5cf6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/><circle cx="12" cy="17" r="2.5" fill="#8b5cf6"/><circle cx="17" cy="21" r="2.5" fill="#c4b5fd"/><circle cx="25" cy="11" r="2.5" fill="#8b5cf6"/><line x1="5" y1="28" x2="29" y2="28" stroke="#2a2833" stroke-width="1.5"/></svg>`,
  },
  {
    slug: 'vio',
    name: 'Vio',
    desc: 'Jouw kleine metgezel die vraagt hoe het gaat — zacht, luchtig of verrassend eerlijk.',
    vio: true,
  },
  {
    slug: 'safe-call',
    name: 'Veiligheidsoproep',
    desc: 'Stel van tevoren in wie ingrijpt – en een deadline waarbinnen je incheckt.',
    icon: `<svg width="34" height="34" viewBox="0 0 34 34" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M17 4L6 8.5V17c0 6 4.925 11.5 11 12.8C23.075 28.5 28 23 28 17V8.5L17 4z" stroke="#8b5cf6" stroke-width="2" stroke-linejoin="round"/><path d="M12 17l3 3 6-6" stroke="#c4b5fd" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
  },
  {
    slug: 'notifications',
    name: 'Meldingen',
    desc: 'Discrete herinneringen die weten wanneer ze moeten verschijnen – en wanneer niet.',
    icon: `<svg width="34" height="34" viewBox="0 0 34 34" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M17 5a7 7 0 0 0-7 7v5l-2 3h18l-2-3v-5a7 7 0 0 0-7-7z" stroke="#8b5cf6" stroke-width="2" stroke-linejoin="round"/><path d="M14 23a3 3 0 0 0 6 0" stroke="#c4b5fd" stroke-width="1.75"/><circle cx="17" cy="5" r="1.5" fill="#8b5cf6"/></svg>`,
  },
  {
    slug: 'vibe-radar',
    name: 'Vibe-Radar',
    desc: 'Een subtiele indicator per verbinding – zie in één oogopslag wie aandacht nodig heeft.',
    icon: `<svg width="34" height="34" viewBox="0 0 34 34" fill="none" xmlns="http://www.w3.org/2000/svg"><circle cx="17" cy="17" r="3" fill="#8b5cf6"/><path d="M11.5 11.5a7.8 7.8 0 0 0 0 11" stroke="#8b5cf6" stroke-width="1.75" stroke-linecap="round"/><path d="M22.5 11.5a7.8 7.8 0 0 1 0 11" stroke="#8b5cf6" stroke-width="1.75" stroke-linecap="round"/><path d="M7 7a14 14 0 0 0 0 19.8" stroke="#c4b5fd" stroke-width="1.5" stroke-linecap="round"/><path d="M27 7a14 14 0 0 1 0 19.8" stroke="#c4b5fd" stroke-width="1.5" stroke-linecap="round"/></svg>`,
  },
];

const faqs = [
  { q: 'Voor wie is Roster gemaakt?', a: 'Voor mensen in polyamoreuze, open of anderszins consensueel niet-monogame relaties die het overzicht willen bewaren — zonder spreadsheets, zonder tracking.' },
  { q: 'Slaat Roster mijn gegevens op in de cloud?', a: 'Nee. Roster is local-first: jouw gegevens staan op jouw apparaat. Er is geen Roster-backend en geen tracking.' },
  { q: 'Heb ik een account nodig?', a: 'Nee. Download de app en begin. Geen registratie, geen e-mail vereist.' },
  { q: 'Wat kost Roster?', a: 'De basis is gratis. Premium kost €0,99/week, €2,99/maand (met 3 dagen gratis) of €29,90/jaar.' },
  { q: 'Op welke apparaten werkt Roster?', a: 'Roster is een native iOS-app voor iPhone, gebouwd met SwiftUI. Beschikbaar in het Duits, Engels, Spaans, Nederlands, Deens en Zweeds.' },
];

const schema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'SoftwareApplication',
      name: 'Roster',
      applicationCategory: 'LifestyleApplication',
      operatingSystem: 'iOS',
      description: 'Privacy-first app voor mensen in polyamoreuze en open relaties. Beheer verbindingen, check-ins en reflecties lokaal — geen account, geen tracking.',
      inLanguage: ['de', 'en', 'es', 'nl', 'da', 'sv'],
      offers: [
        { '@type': 'Offer', price: '0.99', priceCurrency: 'EUR', name: 'Wekelijks' },
        { '@type': 'Offer', price: '2.99', priceCurrency: 'EUR', name: 'Maandelijks' },
        { '@type': 'Offer', price: '29.90', priceCurrency: 'EUR', name: 'Jaarlijks' },
      ],
      author: { '@type': 'Organization', name: 'Slowcraft' },
    },
  ],
};
---

<BaseLayout
  lang={lang}
  path="/"
  title="Roster – Relatie-app voor Polyamorie & Open Relaties"
  description="Roster is een privacy-first app voor polyamoreuze en open relaties. Beheer verbindingen, check-ins en reflecties lokaal — geen account, geen tracking."
  schema={schema}
>
  <Header lang={lang} />
  <main>
    <section class="hero">
      <div class="container hero-grid">
        <div class="hero-copy">
          <p class="eyebrow">Privacy-First · iOS</p>
          <h1>Relaties,<br />zorgvuldig bijgehouden.</h1>
          <p class="lede">
            Roster is de app voor mensen in polyamoreuze en open relaties.
            Houd verbindingen, check-ins en gevoelens bij — lokaal op jouw
            apparaat, geen account, geen tracking.
          </p>
          <div class="hero-cta">
            <a href="https://apps.apple.com/app/roster" class="btn btn-primary">Download in de App Store</a>
            <a href="#features" class="btn btn-ghost">Functies bekijken</a>
          </div>
        </div>
        <div class="hero-visual"><PolyculeMap /></div>
      </div>
    </section>

    <div class="trust">
      <div class="container trust-row">
        <span>Lokaal opgeslagen</span>
        <span>Geen tracking</span>
        <span>Geen account nodig</span>
        <span>Geen backend</span>
      </div>
    </div>

    <section id="features">
      <div class="container">
        <p class="eyebrow">Wat erin zit</p>
        <h2>Vijf ruimtes, één helder hoofd.</h2>
        <p class="lede" style="margin-bottom:48px">Elk tabblad in Roster neemt een deel van de mentale last van meerdere relaties over.</p>
        <div class="grid">
          {features.map((f) => (
            <a href={`/nl/features/${f.slug}`} class="card feature">
              {f.vio ? <Vio size={34} /> : <span class="feat-icon" set:html={f.icon} />}
              <h3>{f.name}</h3>
              <p>{f.desc}</p>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section id="pricing" class="pricing">
      <div class="container">
        <p class="eyebrow">Prijzen</p>
        <h2>Eerlijk, transparant, opzegbaar.</h2>
        <p class="lede" style="margin-bottom:48px">De basis is gratis. Premium ontgrendelt kaart, wellness, inzichten en meer.</p>
        <div class="price-grid">
          <div class="card price">
            <span class="price-name">Wekelijks</span>
            <span class="price-amount">€0,99<small>/week</small></span>
            <p class="price-note">Om te proberen.</p>
          </div>
          <div class="card price">
            <span class="price-name">Maandelijks</span>
            <span class="price-amount">€2,99<small>/maand</small></span>
            <p class="price-note">Inclusief 3 dagen gratis.</p>
          </div>
          <div class="card price featured">
            <span class="badge">Populair</span>
            <span class="price-name">Jaarlijks</span>
            <span class="price-amount">€29,90<small>/jaar</small></span>
            <p class="price-note">Bespaar meer dan 50% t.o.v. maandelijks.</p>
          </div>
        </div>
      </div>
    </section>

    <section id="faq">
      <div class="container faq-wrap">
        <div><p class="eyebrow">FAQ</p><h2>Veelgestelde vragen</h2></div>
        <div class="faq-list">
          {faqs.map((f) => (
            <details class="card faq-item">
              <summary>{f.q}</summary>
              <p>{f.a}</p>
            </details>
          ))}
        </div>
      </div>
    </section>

    <section class="closing">
      <div class="container closing-inner">
        <Vio size={48} />
        <h2>Klaar om je hoofd leeg te maken?</h2>
        <a href="https://apps.apple.com/app/roster" class="btn btn-primary">Roster in de App Store</a>
      </div>
    </section>
  </main>
  <Footer lang={lang} />
</BaseLayout>

<style>
  .hero { padding-top: clamp(48px, 7vw, 88px); }
  .hero-grid { display: grid; grid-template-columns: 1.05fr 0.95fr; align-items: center; gap: 48px; }
  .hero-cta { display: flex; gap: 14px; margin-top: 32px; flex-wrap: wrap; }
  .trust { border-block: 1px solid var(--border); background: var(--surface); }
  .trust-row { display: flex; flex-wrap: wrap; gap: 14px 40px; justify-content: center; padding-block: 20px; color: var(--text-muted); font-size: 0.9rem; }
  .trust-row span { position: relative; padding-left: 20px; }
  .trust-row span::before { content: ''; position: absolute; left: 0; top: 50%; width: 7px; height: 7px; border-radius: 50%; background: var(--accent-teal); transform: translateY(-50%); }
  .grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
  .feature { color: var(--text); text-decoration: none; transition: border-color 0.2s ease, transform 0.15s ease; }
  .feature:hover { text-decoration: none; border-color: var(--purple); transform: translateY(-3px); }
  .feature .feat-icon { display: block; width: 34px; height: 34px; }
  .feature h3 { margin-top: 18px; }
  .feature p { color: var(--text-muted); margin: 0; font-size: 0.96rem; }
  .pricing .price-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
  .price { display: flex; flex-direction: column; position: relative; }
  .price-name { font-size: 0.85rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--text-muted); }
  .price-amount { font-family: var(--font-display); font-size: 2.4rem; margin: 10px 0; }
  .price-amount small { font-family: var(--font-body); font-size: 0.9rem; color: var(--text-dim); }
  .price-note { color: var(--text-muted); font-size: 0.92rem; margin: 0; }
  .price.featured { border-color: var(--purple); box-shadow: 0 0 0 1px var(--purple), 0 20px 50px -20px rgba(139, 92, 246, 0.5); }
  .badge { position: absolute; top: -11px; right: 22px; background: linear-gradient(135deg, var(--purple), var(--purple-deep)); color: #fff; font-size: 0.72rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; padding: 4px 12px; border-radius: 999px; }
  .faq-wrap { display: grid; grid-template-columns: 0.6fr 1.4fr; gap: 40px; align-items: start; }
  .faq-list { display: flex; flex-direction: column; gap: 12px; }
  .faq-item { padding: 0; }
  .faq-item summary { cursor: pointer; list-style: none; padding: 20px 24px; font-weight: 500; display: flex; justify-content: space-between; align-items: center; }
  .faq-item summary::-webkit-details-marker { display: none; }
  .faq-item summary::after { content: '+'; color: var(--purple); font-size: 1.4rem; line-height: 1; }
  .faq-item[open] summary::after { content: '–'; }
  .faq-item p { padding: 0 24px 22px; margin: 0; color: var(--text-muted); }
  .closing-inner { text-align: center; display: flex; flex-direction: column; align-items: center; gap: 18px; }
  .closing h2 { max-width: 16ch; }
  @media (max-width: 860px) {
    .grid { grid-template-columns: 1fr 1fr; } .faq-wrap { grid-template-columns: 1fr; } }
  @media (max-width: 720px) { .hero-grid { grid-template-columns: 1fr; text-align: center; } .hero-cta { justify-content: center; } .hero-visual { order: -1; } .grid {
      grid-template-columns: 1fr;
    }
    .pricing .price-grid {
      gap: 10px;
    }
    .price {
      padding: 16px 12px;
    }
    .price-amount {
      font-size: 1.5rem;
      margin: 6px 0;
    }
    .price-amount small {
      font-size: 0.75rem;
    }
    .price-name {
      font-size: 0.72rem;
      letter-spacing: 0.07em;
    }
    .price-note {
      font-size: 0.78rem;
    } }
</style>
