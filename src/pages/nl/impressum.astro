---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { contact } from '../../config/site';
const lang = 'nl';
---

<BaseLayout
  lang={lang}
  path="/impressum"
  title="Impressum – Roster"
  description="Wettelijke informatie en aanbiederidentificatie voor de Roster-website."
  noindex={true}
>
  <Header lang={lang} />
  <main class="prose container">
    <h1>Impressum</h1>
    <p class="updated">Gegevens conform § 5 DDG (Duitse Wet Digitale Diensten)</p>

    <p>
      <strong>{contact.name}</strong><br />
      {contact.company}<br />
      {contact.addressLine1}<br />
      {contact.addressLine2}<br />
      {contact.city}<br />
      {contact.country}
    </p>

    <h2>Contact</h2>
    <p>
      E-mail: <a href={`mailto:${contact.email}`}>{contact.email}</a><br />
      Telefoon: <a href={`tel:${contact.phone.replace(/\s/g, '')}`}>{contact.phone}</a>
    </p>

    <h2>BTW-identificatienummer</h2>
    <p>BTW-identificatienummer conform § 27 a UStG:<br /><strong>{contact.ustId}</strong></p>

    <h2>Verantwoordelijk voor de inhoud conform § 18 lid 2 MStV</h2>
    <p><strong>{contact.name}</strong>, adres zoals hierboven.</p>

    <h2>EU-geschillenbeslechting</h2>
    <p>
      De Europese Commissie biedt een platform voor online geschillenbeslechting (ODR):
      <a href="https://consumer-redress.ec.europa.eu/index_en?prefLang=nl" rel="noopener">consumer-redress.ec.europa.eu</a>.
      Wij zijn niet bereid of verplicht deel te nemen aan geschillenbeslechtingsprocedures voor een consumentenarbitragecommissie.
    </p>

    <h2>Aansprakelijkheid voor inhoud</h2>
    <p>Als dienstverlener zijn wij conform § 7 lid 1 DDG verantwoordelijk voor onze eigen inhoud op deze pagina's. Wij zijn niet verplicht om doorgezonden of opgeslagen informatie van derden te controleren.</p>

    <h2>Auteursrecht</h2>
    <p>De door de sitebeheerder gemaakte inhoud en werken op deze pagina's zijn onderworpen aan het Duitse auteursrecht. Reproductie, bewerking, verspreiding en elke vorm van exploitatie buiten de grenzen van het auteursrecht vereisen de schriftelijke toestemming van de betreffende auteur.</p>
  </main>
  <Footer lang={lang} />
</BaseLayout>

<style>
  .prose { max-width: 720px; padding-block: 80px; }
  .prose h1 { margin-bottom: 0.3em; }
  .updated { color: var(--text-dim); font-size: 0.88rem; margin-bottom: 2em; }
  .prose h2 { font-size: 1.25rem; margin-top: 2em; }
  .prose p { color: var(--text-muted); line-height: 1.7; }
  .prose a { color: var(--accent); }
</style>
