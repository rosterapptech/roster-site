---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import { getCollection, render } from 'astro:content';
import { t } from '../../../i18n/ui';
import { blogAlternates } from '../../../i18n/blogAlternates';

export const prerender = true;

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts
    .filter((p) => p.data.lang === 'sv')
    .map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const posts = await getCollection('blog');
const { Content } = await render(post);
const lang = 'sv';
const tr = t(lang);
const alternates = blogAlternates(posts, post, Astro.site!);

const fmt = (d: Date) =>
  d.toLocaleDateString('sv-SE', { year: 'numeric', month: 'long', day: 'numeric' });

const schema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.pubDate.toISOString(),
  ...(post.data.updatedDate && { dateModified: post.data.updatedDate.toISOString() }),
  author: { '@type': 'Organization', name: post.data.author },
  inLanguage: lang,
};
---

<BaseLayout
  lang={lang}
  path={`/blog/${post.id}`}
  title={`${post.data.title} – Roster`}
  description={post.data.description}
  schema={schema}
  alternates={alternates}
>
  <Header lang={lang} />
  <main class="container article">
    <a href="/sv/blog" class="back">{tr('blog.back')}</a>
    <time datetime={post.data.pubDate.toISOString()}>{fmt(post.data.pubDate)}</time>
    <h1>{post.data.title}</h1>
    <div class="body">
      <Content />
    </div>
  </main>
  <Footer lang={lang} />
</BaseLayout>

<style>
  .article { max-width: 720px; padding-block: 60px 80px; }
  .back { color: var(--text-muted); font-size: 0.9rem; }
  .article time { display: block; color: var(--text-dim); font-size: 0.85rem; margin-top: 24px; }
  .article h1 { margin: 8px 0 32px; }
  .body :global(h2) { font-size: 1.5rem; margin-top: 1.8em; }
  .body :global(p) { color: var(--text-muted); line-height: 1.75; }
  .body :global(blockquote) { border-left: 3px solid var(--purple); margin: 1.5em 0; padding: 4px 0 4px 20px; color: var(--lavender); font-style: italic; }
  .body :global(strong) { color: var(--text); }
</style>
