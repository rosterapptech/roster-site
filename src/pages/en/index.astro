---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import PolyculeMap from '../../components/PolyculeMap.astro';
import Vio from '../../components/Vio.astro';

const lang = 'en';

const features = [
  {
    slug: 'connections',
    name: 'Connections',
    desc: 'Every relationship in one place — with type, protection status and a quick contact log.',
    icon: `<svg width="34" height="34" viewBox="0 0 34 34" fill="none" xmlns="http://www.w3.org/2000/svg"><circle cx="12" cy="13" r="5" stroke="#8b5cf6" stroke-width="2"/><path d="M3 28c0-4.418 4.03-8 9-8s9 3.582 9 8" stroke="#8b5cf6" stroke-width="2" stroke-linecap="round"/><circle cx="25" cy="11" r="4" stroke="#c4b5fd" stroke-width="1.75"/><path d="M20 26c0-3.314 2.686-6 6-6" stroke="#c4b5fd" stroke-width="1.75" stroke-linecap="round"/></svg>`,
  },
  {
    slug: 'polycule-map',
    name: 'Polycule Map',
    desc: 'Your relationship web as a living map. You at the center, every connection colour-coded by type.',
    icon: `<svg width="34" height="34" viewBox="0 0 34 34" fill="none" xmlns="http://www.w3.org/2000/svg"><circle cx="17" cy="17" r="4" fill="#8b5cf6"/><circle cx="6" cy="9" r="3" stroke="#8b5cf6" stroke-width="1.75"/><circle cx="28" cy="9" r="3" stroke="#c4b5fd" stroke-width="1.75"/><circle cx="6" cy="25" r="3" stroke="#4fd6c2" stroke-width="1.75"/><circle cx="28" cy="25" r="3" stroke="#f0789f" stroke-width="1.75"/><line x1="17" y1="17" x2="6" y2="9" stroke="#8b5cf6" stroke-width="1.5" stroke-opacity="0.6"/><line x1="17" y1="17" x2="28" y2="9" stroke="#c4b5fd" stroke-width="1.5" stroke-opacity="0.6"/><line x1="17" y1="17" x2="6" y2="25" stroke="#4fd6c2" stroke-width="1.5" stroke-opacity="0.6"/><line x1="17" y1="17" x2="28" y2="25" stroke="#f0789f" stroke-width="1.5" stroke-opacity="0.6"/></svg>`,
  },
  {
    slug: 'wellness',
    name: 'Wellness',
    desc: 'Keep STI tests and check-ins in view — discreet, local, seen by no one but you.',
    icon: `<svg width="34" height="34" viewBox="0 0 34 34" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M17 29C17 29 5 22 5 13a7 7 0 0 1 12-4.9A7 7 0 0 1 29 13c0 9-12 16-12 16z" stroke="#8b5cf6" stroke-width="2" stroke-linejoin="round"/><path d="M12 17l3 3 6-6" stroke="#c4b5fd" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
  },
  {
    slug: 'reflection',
    name: 'Reflection',
    desc: 'A journal for jealousy, compersion and everything between. To sort, not to judge.',
    icon: `<svg width="34" height="34" viewBox="0 0 34 34" fill="none" xmlns="http://www.w3.org/2000/svg"><rect x="6" y="5" width="16" height="24" rx="3" stroke="#8b5cf6" stroke-width="2"/><path d="M22 8h3a3 3 0 0 1 3 3v13a3 3 0 0 1-3 3h-3" stroke="#c4b5fd" stroke-width="1.75"/><line x1="10" y1="11" x2="18" y2="11" stroke="#8b5cf6" stroke-width="1.75" stroke-linecap="round"/><line x1="10" y1="16" x2="18" y2="16" stroke="#8b5cf6" stroke-width="1.75" stroke-linecap="round"/><line x1="10" y1="21" x2="15" y2="21" stroke="#8b5cf6" stroke-width="1.75" stroke-linecap="round"/></svg>`,
  },
  {
    slug: 'insights',
    name: 'Insights',
    desc: 'Gentle patterns over cold numbers: where you invest energy, where things go quiet.',
    icon: `<svg width="34" height="34" viewBox="0 0 34 34" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M5 24l7-7 5 4 8-10 4 4" stroke="#8b5cf6" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/><circle cx="12" cy="17" r="2.5" fill="#8b5cf6"/><circle cx="17" cy="21" r="2.5" fill="#c4b5fd"/><circle cx="25" cy="11" r="2.5" fill="#8b5cf6"/><line x1="5" y1="28" x2="29" y2="28" stroke="#2a2833" stroke-width="1.5"/></svg>`,
  },
  {
    slug: 'vio',
    name: 'Vio',
    desc: 'Your little companion who checks in on you — gentle, casual, or brutally honest.',
    vio: true,
  },
];

const faqs = [
  { q: 'Who is Roster for?', a: 'People in polyamorous, open or otherwise ethically non-monogamous relationships who want to stay on top of things — without spreadsheets, without tracking.' },
  { q: 'Does Roster store my data in the cloud?', a: 'No. Roster is local-first: your data lives on your device. There is no Roster backend and no tracking.' },
  { q: 'Do I need an account?', a: 'No. Download the app and start. No sign-up, no email required.' },
  { q: 'What does Roster cost?', a: 'The basics are free. Premium is €0.99/week, €2.99/month (with a 3-day free trial) or €29.90/year.' },
  { q: 'Which devices does Roster run on?', a: 'Roster is a native iOS app for iPhone, built with SwiftUI. Available in German, English, Spanish, Dutch, Danish and Swedish.' },
  { q: 'What is Vio?', a: 'Vio is your personal companion inside the app — a gentle inner voice that checks in with you daily. Sometimes light, sometimes deeper. Vio retains nothing long-term; everything stays on your device.' },
];

const schema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'SoftwareApplication',
      name: 'Roster',
      applicationCategory: 'LifestyleApplication',
      operatingSystem: 'iOS',
      description: 'Privacy-first app for people in polyamorous and open relationships. Organize connections, check-ins and reflections locally — no account, no tracking.',
      inLanguage: ['de', 'en', 'es', 'nl', 'da', 'sv'],
      offers: [
        { '@type': 'Offer', price: '0.99', priceCurrency: 'EUR', name: 'Weekly' },
        { '@type': 'Offer', price: '2.99', priceCurrency: 'EUR', name: 'Monthly' },
        { '@type': 'Offer', price: '29.90', priceCurrency: 'EUR', name: 'Yearly' },
      ],
      author: { '@type': 'Organization', name: 'Slowcraft' },
    },
    {
      '@type': 'FAQPage',
      mainEntity: faqs.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })),
    },
  ],
};
---

<BaseLayout
  lang={lang}
  path="/"
  title="Roster – Relationship App for Polyamory & Open Relationships"
  description="Roster is a privacy-first app for polyamorous and open relationships. Organize your connections, check-ins and reflections locally — no account, no tracking."
  schema={schema}
>
  <Header lang={lang} />
  <main>
    <section class="hero">
      <div class="container hero-grid">
        <div class="hero-copy">
          <p class="eyebrow">Privacy-First · iOS</p>
          <h1>Relationships,<br />tended with care.</h1>
          <p class="lede">
            Roster is the app for people in polyamorous and open relationships.
            Keep your connections, check-ins and feelings in view — local on your
            device, no account, no tracking.
          </p>
          <div class="hero-cta">
            <a href="https://apps.apple.com/app/roster" class="btn btn-primary">Get it on the App Store</a>
            <a href="#features" class="btn btn-ghost">See features</a>
          </div>
        </div>
        <div class="hero-visual"><PolyculeMap /></div>
      </div>
    </section>

    <div class="trust">
      <div class="container trust-row">
        <span>Stored locally</span>
        <span>No tracking</span>
        <span>No account required</span>
        <span>No backend</span>
      </div>
    </div>

    <section id="features">
      <div class="container">
        <p class="eyebrow">What's inside</p>
        <h2>Five rooms, one clear head.</h2>
        <p class="lede" style="margin-bottom:48px">Each tab in Roster takes over a part of the mental load that multiple relationships bring.</p>
        <div class="grid">
          {features.map((f) => (
            <a href={`/en/features/${f.slug}`} class="card feature">
              {f.vio ? <Vio size={34} /> : <span class="feat-icon" set:html={f.icon} />}
              <h3>{f.name}</h3>
              <p>{f.desc}</p>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section id="pricing" class="pricing">
      <div class="container">
        <p class="eyebrow">Pricing</p>
        <h2>Fair, honest, cancellable.</h2>
        <p class="lede" style="margin-bottom:48px">The basics are free. Premium unlocks the map, wellness, insights and more.</p>
        <div class="price-grid">
          <div class="card price">
            <span class="price-name">Weekly</span>
            <span class="price-amount">€0.99<small>/week</small></span>
            <p class="price-note">To try it out.</p>
          </div>
          <div class="card price">
            <span class="price-name">Monthly</span>
            <span class="price-amount">€2.99<small>/month</small></span>
            <p class="price-note">Includes 3 days free.</p>
          </div>
          <div class="card price featured">
            <span class="badge">Popular</span>
            <span class="price-name">Yearly</span>
            <span class="price-amount">€29.90<small>/year</small></span>
            <p class="price-note">Save over 50% vs monthly.</p>
          </div>
        </div>
      </div>
    </section>

    <section id="faq">
      <div class="container faq-wrap">
        <div><p class="eyebrow">FAQ</p><h2>Common questions</h2></div>
        <div class="faq-list">
          {faqs.map((f) => (
            <details class="card faq-item">
              <summary>{f.q}</summary>
              <p>{f.a}</p>
            </details>
          ))}
        </div>
      </div>
    </section>

    <section class="closing">
      <div class="container closing-inner">
        <Vio size={48} />
        <h2>Ready to clear your head?</h2>
        <a href="https://apps.apple.com/app/roster" class="btn btn-primary">Get Roster on the App Store</a>
      </div>
    </section>
  </main>
  <Footer lang={lang} />
</BaseLayout>

<style>
  .hero { padding-top: clamp(48px, 7vw, 88px); }
  .hero-grid { display: grid; grid-template-columns: 1.05fr 0.95fr; align-items: center; gap: 48px; }
  .hero-cta { display: flex; gap: 14px; margin-top: 32px; flex-wrap: wrap; }
  .trust { border-block: 1px solid var(--border); background: var(--surface); }
  .trust-row { display: flex; flex-wrap: wrap; gap: 14px 40px; justify-content: center; padding-block: 20px; color: var(--text-muted); font-size: 0.9rem; }
  .trust-row span { position: relative; padding-left: 20px; }
  .trust-row span::before { content: ''; position: absolute; left: 0; top: 50%; width: 7px; height: 7px; border-radius: 50%; background: var(--accent-teal); transform: translateY(-50%); }
  .grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
  .feature { color: var(--text); text-decoration: none; transition: border-color 0.2s ease, transform 0.15s ease; }
  .feature:hover { text-decoration: none; border-color: var(--purple); transform: translateY(-3px); }
  .feature .feat-icon { display: block; width: 34px; height: 34px; }
  .feature h3 { margin-top: 18px; }
  .feature p { color: var(--text-muted); margin: 0; font-size: 0.96rem; }
  .pricing .price-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
  .price { display: flex; flex-direction: column; position: relative; }
  .price-name { font-size: 0.85rem; letter-spacing: 0.1em; text-transform: uppercase; color: var(--text-muted); }
  .price-amount { font-family: var(--font-display); font-size: 2.4rem; margin: 10px 0; }
  .price-amount small { font-family: var(--font-body); font-size: 0.9rem; color: var(--text-dim); }
  .price-note { color: var(--text-muted); font-size: 0.92rem; margin: 0; }
  .price.featured { border-color: var(--purple); box-shadow: 0 0 0 1px var(--purple), 0 20px 50px -20px rgba(139, 92, 246, 0.5); }
  .badge { position: absolute; top: -11px; right: 22px; background: linear-gradient(135deg, var(--purple), var(--purple-deep)); color: #fff; font-size: 0.72rem; font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; padding: 4px 12px; border-radius: 999px; }
  .faq-wrap { display: grid; grid-template-columns: 0.6fr 1.4fr; gap: 40px; align-items: start; }
  .faq-list { display: flex; flex-direction: column; gap: 12px; }
  .faq-item { padding: 0; }
  .faq-item summary { cursor: pointer; list-style: none; padding: 20px 24px; font-weight: 500; display: flex; justify-content: space-between; align-items: center; }
  .faq-item summary::-webkit-details-marker { display: none; }
  .faq-item summary::after { content: '+'; color: var(--purple); font-size: 1.4rem; line-height: 1; }
  .faq-item[open] summary::after { content: '–'; }
  .faq-item p { padding: 0 24px 22px; margin: 0; color: var(--text-muted); }
  .closing-inner { text-align: center; display: flex; flex-direction: column; align-items: center; gap: 18px; }
  .closing h2 { max-width: 16ch; }
  @media (max-width: 860px) { .grid, .pricing .price-grid { grid-template-columns: 1fr 1fr; } .faq-wrap { grid-template-columns: 1fr; } }
  @media (max-width: 720px) { .hero-grid { grid-template-columns: 1fr; text-align: center; } .hero-cta { justify-content: center; } .hero-visual { order: -1; } .grid, .pricing .price-grid { grid-template-columns: 1fr; } }
</style>
