---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { contact, websiteFeatures } from '../../config/site';
const lang = 'en';
const today = new Date().toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' });
---

<BaseLayout
  lang={lang}
  path="/datenschutz"
  title="Privacy Policy – Roster"
  description="Privacy policy for the Roster website. No tracking, no backend."
  noindex={true}
>
  <Header lang={lang} />
  <main class="prose container">
    <h1>Privacy Policy</h1>
    <p class="updated">Last updated: {today}</p>

    <h2>1. Controller</h2>
    <p>
      <strong>{contact.name}</strong><br />
      {contact.company} · {contact.addressLine1} · {contact.addressLine2} · {contact.city}<br />
      Email: <a href={`mailto:${contact.email}`}>{contact.email}</a>
    </p>

    <h2>2. This Website</h2>
    <p>This website is the marketing presence for the Roster iOS app. No user accounts are created, no forms are processed, and no tracking is performed.</p>

    {websiteFeatures.hosting ? (
      <h2>3. Hosting &amp; Server Logs</h2>
      <p>This website is hosted by <strong>{websiteFeatures.hosting}</strong>. When you visit, the hosting provider processes technically necessary server logs (e.g. IP address, timestamp, requested page) for delivery and security purposes. Legal basis: Art. 6(1)(f) GDPR.</p>
    ) : (
      <h2>3. Hosting &amp; Server Logs</h2>
      <p>When you visit this website, the hosting provider processes technically necessary server logs (e.g. IP address, timestamp, requested page) for delivery and security purposes. Legal basis: Art. 6(1)(f) GDPR.</p>
    )}

    <h2>4. Fonts</h2>
    {websiteFeatures.externalFonts ? (
      <p>This website loads fonts from an external CDN. Your IP address is transmitted to the provider. Legal basis: Art. 6(1)(f) GDPR.</p>
    ) : (
      <p>All fonts are self-hosted. No external font CDNs are called.</p>
    )}

    {websiteFeatures.analytics && (
      <h2>5. Analytics</h2>
      <p>This website uses <strong>{websiteFeatures.analytics}</strong> for anonymised reach measurement. No personal data is stored. Legal basis: Art. 6(1)(f) GDPR.</p>
    )}

    {websiteFeatures.cookies && (
      <h2>Cookies</h2>
      <p>This website uses cookies. Your consent is requested on your first visit. Technically necessary cookies are exempt from consent.</p>
    )}

    {websiteFeatures.contactForm && (
      <h2>Contact Form</h2>
      <p>If you use the contact form, the data you enter will be processed to handle your enquiry and deleted afterwards. Legal basis: Art. 6(1)(b) GDPR.</p>
    )}

    {websiteFeatures.newsletter && (
      <h2>Newsletter</h2>
      <p>If you sign up for the newsletter, we use your email address solely for sending it. Legal basis: Art. 6(1)(a) GDPR. You can unsubscribe at any time.</p>
    )}

    <h2>The Roster App</h2>
    <p>
      Roster stores all content exclusively on your device. There is no Roster backend and no transmission of your content to us. The full app privacy policy is available at <a href="/en/appinfo/datenschutzrichtlinie">rosterapp.tech/en/appinfo/datenschutzrichtlinie</a>.
    </p>

    <h2>Your Rights</h2>
    <p>You have the rights under Art. 15–22 GDPR: access, rectification, erasure, restriction, data portability, and objection. You also have the right to lodge a complaint with your national data protection authority (Art. 77 GDPR). Contact: <a href={`mailto:${contact.email}`}>{contact.email}</a>.</p>
  </main>
  <Footer lang={lang} />
</BaseLayout>

<style>
  .prose { max-width: 720px; padding-block: 80px; }
  .prose h1 { margin-bottom: 0.3em; }
  .updated { color: var(--text-dim); font-size: 0.88rem; margin-bottom: 2em; }
  .prose h2 { font-size: 1.25rem; margin-top: 2em; }
  .prose p { color: var(--text-muted); line-height: 1.7; }
  .prose a { color: var(--accent); }
</style>
