---
import '../styles/global.css';
import Analytics from '@vercel/analytics/astro';
import type { Lang } from '../i18n/ui';

interface Props {
  title: string;
  description: string;
  lang?: Lang;
  /** Pfad ohne Sprachpraefix, z.B. "/" oder "/blog" – fuer hreflang */
  path?: string;
  /** Optionales JSON-LD-Objekt (z.B. SoftwareApplication, Article) */
  schema?: Record<string, unknown>;
  /** Soll diese Seite indexiert werden? Rechtsseiten z.B. auf noindex. */
  noindex?: boolean;
  /**
   * Explizite hreflang-Alternates (volle URLs). Noetig fuer Seiten mit
   * sprachspezifischen Slugs (z.B. Blog), wo `/${lang}${path}` nicht stimmt.
   * Wenn nicht gesetzt, werden die Alternates aus `path` abgeleitet.
   */
  alternates?: { hreflang: string; href: string }[];
  /** og:type – 'website' (Default) oder 'article' fuer Blog-Beitraege. */
  ogType?: string;
  /** ISO-Datum: setzt article:published_time (nur bei ogType 'article' sinnvoll). */
  publishedTime?: string;
  /** ISO-Datum: setzt article:modified_time. */
  modifiedTime?: string;
}

const {
  title,
  description,
  lang = 'de',
  path = '/',
  schema,
  noindex = false,
  alternates: alternatesProp,
  ogType = 'website',
  publishedTime,
  modifiedTime,
} = Astro.props;

const site = Astro.site ?? new URL('https://rosterapp.tech');
const canonical = new URL(lang === 'de' ? path : `/${lang}${path}`, site).href;

const ogLocale = {
  de: 'de_DE',
  en: 'en_US',
  nl: 'nl_NL',
  es: 'es_ES',
  da: 'da_DK',
  sv: 'sv_SE',
}[lang] ?? 'de_DE';

const alternates = alternatesProp ?? [
  { hreflang: 'de', href: new URL(path, site).href },
  { hreflang: 'en', href: new URL(`/en${path}`, site).href },
  { hreflang: 'nl', href: new URL(`/nl${path}`, site).href },
  { hreflang: 'es', href: new URL(`/es${path}`, site).href },
  { hreflang: 'da', href: new URL(`/da${path}`, site).href },
  { hreflang: 'sv', href: new URL(`/sv${path}`, site).href },
  { hreflang: 'x-default', href: new URL(path, site).href },
];
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex, follow" />}

    {alternates.map((a) => (
      <link rel="alternate" hreflang={a.hreflang} href={a.href} />
    ))}

    <!-- Open Graph / Social -->
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={new URL('/og.png', site).href} />
    <meta property="og:locale" content={ogLocale} />
    {ogType === 'article' && publishedTime && (
      <meta property="article:published_time" content={publishedTime} />
    )}
    {ogType === 'article' && modifiedTime && (
      <meta property="article:modified_time" content={modifiedTime} />
    )}
    <meta name="twitter:card" content="summary_large_image" />

    <!-- JSON-LD: macht die Seite fuer KI-Systeme maschinenlesbar -->
    {schema && (
      <script
        type="application/ld+json"
        set:html={JSON.stringify(schema)}
      />
    )}

    <slot name="head" />
  </head>
  <body>
    <slot />
    <Analytics />
    <script>
      // Aktiviert Scroll-Reveal erst wenn JS läuft → Content immer im DOM (SEO-sicher)
      document.documentElement.classList.add('js-ready');

      const observer = new IntersectionObserver(
        (entries) => entries.forEach((e) => {
          if (e.isIntersecting) {
            e.target.classList.add('revealed');
            observer.unobserve(e.target);
          }
        }),
        { threshold: 0.08, rootMargin: '0px 0px -32px 0px' }
      );

      // Karten & Gitter automatisch mit gestaffelten Delays
      document.querySelectorAll('.grid, .price-grid, .faq-list, .posts').forEach((wrap) => {
        wrap.querySelectorAll(':scope > *').forEach((child, i) => {
          child.setAttribute('data-reveal', '');
          child.setAttribute('data-delay', String(Math.min(i + 1, 6)));
          observer.observe(child);
        });
      });

      // Überschriften, Abschnitte & Feature-Seiten-Elemente
      document.querySelectorAll(
        'section .eyebrow, section > .container > h2, .closing-inner, ' +
        '.feature-header, .long-desc, .screenshot-area, .back, ' +
        '.trust-row, .blog-index .eyebrow, .blog-index h1, .blog-index .lede'
      ).forEach((el) => {
        el.setAttribute('data-reveal', '');
        observer.observe(el);
      });
    </script>
  </body>
</html>
