---
interface Props {
  size?: number;
}
const { size = 28 } = Astro.props;
---

<span class="vio" style={`--vio-size:${size}px`} aria-hidden="true">
  <svg viewBox="0 0 64 64" xmlns="http://www.w3.org/2000/svg">
    <path
      d="M32 56C32 56 6 40 6 22C6 13 13 7 21 7C26 7 30 9 32 13C34 9 38 7 43 7C51 7 58 13 58 22C58 40 32 56 32 56Z"
      fill="var(--purple)"
    />
    <circle cx="24" cy="26" r="4.2" fill="#fff" />
    <circle cx="40" cy="26" r="4.2" fill="#fff" />
    <circle cx="25" cy="27" r="2" fill="#1b1a22" />
    <circle cx="41" cy="27" r="2" fill="#1b1a22" />
  </svg>
</span>

<style>
  .vio {
    display: inline-flex;
    width: var(--vio-size);
    height: var(--vio-size);
  }
  .vio svg {
    width: 100%;
    height: 100%;
  }
</style>
