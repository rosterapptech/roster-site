---
import Vio from './Vio.astro';
import { t, type Lang } from '../i18n/ui';

interface Props {
  lang?: Lang;
}
const { lang = 'de' } = Astro.props;
const tr = t(lang);
const base = lang === 'de' ? '' : `/${lang}`;
---

<header class="site-header">
  <div class="container bar">
    <a href={`${base}/`} class="brand" aria-label="Roster Startseite">
      <Vio size={26} />
      <span class="wordmark">Roster</span>
    </a>

    <nav class="nav" aria-label="Hauptnavigation">
      <a href={`${base}/#features`}>{tr('nav.features')}</a>
      <a href={`${base}/#pricing`}>{tr('nav.pricing')}</a>
      <a href={`${base}/blog`}>{tr('nav.blog')}</a>
    </nav>

    <a
      href="https://apps.apple.com/app/roster"
      class="btn btn-primary header-cta"
      rel="noopener">{tr('nav.cta')}</a>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    backdrop-filter: blur(12px);
    background: rgba(10, 11, 13, 0.72);
    border-bottom: 1px solid var(--border);
  }
  .bar {
    display: flex;
    align-items: center;
    gap: 24px;
    height: 68px;
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    color: var(--text);
  }
  .brand:hover {
    text-decoration: none;
  }
  .wordmark {
    font-family: var(--font-display);
    font-size: 1.45rem;
    letter-spacing: -0.02em;
  }
  .nav {
    display: flex;
    gap: 28px;
    margin-left: auto;
  }
  .nav a {
    color: var(--text-muted);
    font-size: 0.95rem;
    font-weight: 400;
  }
  .nav a:hover {
    color: var(--text);
    text-decoration: none;
  }
  .header-cta {
    font-size: 0.9rem;
    padding: 0.6em 1.1em;
  }
  @media (max-width: 720px) {
    .nav {
      display: none;
    }
    .header-cta {
      margin-left: auto;
    }
  }
</style>
