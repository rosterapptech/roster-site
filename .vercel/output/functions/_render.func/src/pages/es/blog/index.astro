---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import { getCollection } from 'astro:content';
import { t } from '../../../i18n/ui';

const lang = 'es';
const tr = t(lang);
const posts = (await getCollection('blog'))
  .filter((p) => p.data.lang === lang)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const fmt = (d: Date) =>
  d.toLocaleDateString('es-ES', { year: 'numeric', month: 'long', day: 'numeric' });
---

<BaseLayout lang={lang} path="/blog" title="Blog – Roster" description="">
  <Header lang={lang} />
  <main class="container blog-index">
    <p class="eyebrow">Blog</p>
    <h1>{tr('blog.headline')}</h1>
    <p class="lede">{tr('blog.lede')}</p>
    <div class="posts">
      {posts.map((post) => (
        <a href={`/es/blog/${post.id}`} class="card post">
          <time datetime={post.data.pubDate.toISOString()}>{fmt(post.data.pubDate)}</time>
          <h2>{post.data.title}</h2>
          <p>{post.data.description}</p>
          <span class="more">{tr('blog.readmore')}</span>
        </a>
      ))}
    </div>
  </main>
  <Footer lang={lang} />
</BaseLayout>

<style>
  .blog-index { padding-block: 80px; }
  .blog-index h1 { margin-top: 0.3em; }
  .posts { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-top: 48px; }
  .post { display: flex; flex-direction: column; color: var(--text); transition: border-color 0.2s ease, transform 0.15s ease; }
  .post:hover { text-decoration: none; border-color: var(--purple); transform: translateY(-3px); }
  .post time { color: var(--text-dim); font-size: 0.82rem; }
  .post h2 { font-size: 1.4rem; margin: 10px 0 8px; }
  .post p { color: var(--text-muted); font-size: 0.95rem; flex-grow: 1; }
  .more { color: var(--lavender); font-size: 0.9rem; margin-top: 12px; }
  @media (max-width: 720px) { .posts { grid-template-columns: 1fr; } }
</style>
